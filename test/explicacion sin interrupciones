// desde arriba hacia abajo

int sensores[4] = {1, 2, 3, 4};
int puls = 5;
int segPines[7] = {6, 7, 8, 9, 10, 11, 12};
int sensor_activo;
/*Estas son las conexiones físicas. sensores guarda los 4 pines donde están conectados los sensores de cada
estación de la línea de montaje. puls es el pin del pulsador que usa el operario. segPines son los 7 pines
donde está conectado cada segmento del display (a,b,c,d,e,f,g en ese orden). sensor_activo va a guardar, en
cada momento, cuál de los 4 sensores está detectando el producto (0, 1, 2 o 3).*/

int d7s[6][7] = {
    {0,1,1,0,0,0,0}, //1
    {1,0,1,1,0,1,1}, //2
    {1,0,0,1,1,1,1}, //3
    {0,1,1,0,0,1,1}, //4
    {1,0,0,1,1,1,0}, //C
    {0,0,0,0,0,0,1}, //-
};
/*Es la tabla de patrones del display: cada fila representa qué segmentos hay que prender (1) o apagar (0)
para mostrar ese carácter. La fila 0 es el "1", la fila 3 es el "4", la fila 4 es la "C" y la fila 5 es el
guion. Por eso después en el código vas a ver cosas como d7s[3][i]: fila 3 (el "4"), columna i
(cada uno de los 7 segmentos).*/

volatile unsigned long t_previo_espera = 0;
unsigned long t_delay_espera = 10000;

unsigned long t_previo_parpadeo = 0;
unsigned long t_delay_parpadeo = 500;

volatile bool guion_activo = false;
/*Estas son las variables del "cronómetro". t_previo_espera guarda el instante en que el
producto llegó a la etapa 4, y se compara contra t_delay_espera (10000 ms) para saber cuándo pasar al parpadeo.
t_previo_parpadeo y t_delay_parpadeo hacen lo mismo pero para el parpadeo de la C cada 500ms. guion_activo es
el flag que indica si el display tiene que estar mostrando el guion fijo. Las dos primeras son volatile porque
las toca tanto la interrupción como el loop() normal; si no fueran volatile, el compilador podría guardarlas en
un registro y "no enterarse" de que la interrupción las cambió por su cuenta.*/

void IRAM_ATTR toggle() {
  if (millis() - t_previo_espera >= t_delay_espera) {
    guion_activo = true;
  }
}
/*Esta es la función que se ejecuta automáticamente cuando se presiona el pulsador, sin que el loop() tenga que
estar revisándolo. IRAM_ATTR es específico de ESP32 y obliga a que este código quede en la memoria RAM en vez de
la flash, porque las interrupciones necesitan ejecutarse muy rápido y sin depender de accesos más lentos.
Adentro, la condición millis() - t_previo_espera >= t_delay_espera chequea si ya pasaron los 10 segundos desde
que llegamos a la etapa 4; si el operario presiona el botón antes de eso (por ejemplo, mientras todavía se
muestra el "4" fijo), no pasa nada. Solo si ya se cumplió esa espera, se activa guion_activo.*/

void setup() {
  for (int i = 0; i < 4; i++) {
    pinMode(sensores[i], INPUT);
  }
  pinMode(puls, INPUT_PULLUP);
  attachInterrupt(digitalPinToInterrupt(puls), toggle, FALLING);
  for (int i = 0; i < 7; i++) {
    pinMode(segPines[i], OUTPUT);
  }
}
/*Configuracion de los pines: los 4 sensores como entradas, el pulsador como INPUT_PULLUP
(queda en HIGH en reposo gracias a una resistencia interna, y baja a LOW al presionarlo), y los 7 pines
del display como salidas. attachInterrupt es lo que conecta el pin del pulsador con la función toggle():
le dice al microcontrolador "cada vez que en este pin haya un flanco FALLING (de HIGH a LOW, que es justo
lo que pasa al presionar con INPUT_PULLUP), pausá lo que estés haciendo y ejecutá toggle() inmediatamente".*/

void loop() {

  if (guion_activo) {
    for (int i = 0; i < 7; i++)
      digitalWrite(segPines[i], d7s[5][i]);

    if (digitalRead(sensores[0])) {
      guion_activo = false;
      sensor_activo = 0;
      t_previo_espera = 0;
    }
    return;
  }
/*Esta es la primera cosa que se chequea en cada vuelta del loop(). Si guion_activo es true (porque se presionó
el botón estando en la C), escribe el patrón del guion en los 7 segmentos y se queda esperando únicamente a que
sensores[0] detecte algo. Cuando eso pasa, apaga la bandera, fuerza sensor_activo = 0 para que la próxima
vuelta entre directo al case 0, y resetea t_previo_espera a 0 para que el cronómetro de los 10 segundos arranque
de cero la próxima vez. El return corta ahí la ejecución de esta vuelta del loop, así mientras estemos en modo
guion nunca se llega a leer los otros 3 sensores ni a entrar al switch.*/

for (int j = 0; j < 4; j++) {
    if (digitalRead(sensores[j]))
      sensor_activo = j;
  }
/*Si no estamos en modo guion, este bloque recorre los 4 sensores y, si alguno está en HIGH, guarda su índice
en sensor_activo para el switch.*/

switch (sensor_activo) {
    case 0:
      t_previo_espera = 0;
      for (int i = 0; i < 7; i++)
        digitalWrite(segPines[i], d7s[0][i]);
      break;

    case 1:
      for (int i = 0; i < 7; i++)
        digitalWrite(segPines[i], d7s[1][i]);
      break;

      case 2:
      for (int i = 0; i < 7; i++)
        digitalWrite(segPines[i], d7s[2][i]);
      break;
/*El switch decide qué mostrar según en qué estación está el producto. Los case 0, 1 y 2 son simples: escriben
el patrón correspondiente (d7s[0], d7s[1], d7s[2]) en los 7 segmentos. El case 0 además resetea t_previo_espera,
porque es la señal de que arrancó un producto nuevo desde el principio de la línea.*/

case 3:
      if (t_previo_espera == 0) {
        t_previo_espera = millis();
      }
/*Pregunta si t_previo_espera está en 0. Como esa variable se resetea a 0 en el case 0 (cuando arranca un
producto nuevo), esta condición solo es verdadera la primera vez que el producto llega a esta etapa. Si es
verdadera, guarda en t_previo_espera el valor que devuelve millis() en ese instante, o sea "cuántos milisegundos
pasaron desde que arrancó la placa hasta ahora". A partir de la siguiente vuelta del loop, esta variable ya no
es 0, así que este bloque no se vuelve a ejecutar.*/

 if (millis() - t_previo_espera < t_delay_espera) {
/*Calcula millis() (el instante actual) menos t_previo_espera (el instante en que llegó). El resultado es el
tiempo transcurrido desde que el producto está en esta estación. Compara ese tiempo contra t_delay_espera
(10000 ms). Si todavía no pasaron los 10 segundos, esta condición es verdadera.*/

 for (int i = 0; i < 7; i++) digitalWrite(segPines[i], d7s[3][i]);
 /*Solo se ejecuta si la condición anterior fue verdadera. Recorre los 7 pines del display (i de 0 a 6)
 y a cada uno le escribe el valor que indica d7s[3][i] (la fila del número "4" en la tabla de patrones).
 Esto deja el display mostrando "4".*/

} else {
/*Si en cambio ya pasaron 10 segundos o más, entra acá en vez del bloque anterior.*/

 if (millis() - t_previo_parpadeo >= t_delay_parpadeo) {
/*Mismo mecanismo que el primer if, pero con otro par de variables: calcula cuánto pasó desde la última vez que
se cambió el estado del parpadeo (t_previo_parpadeo) y lo compara contra 500 ms (t_delay_parpadeo). Si todavía
no pasó ese tiempo, no entra acá y no se hace nada (el display se queda como estaba).*/

 t_previo_parpadeo = millis();
/*Si sí se cumplieron los 500ms, lo primero que hace es actualizar t_previo_parpadeo con el instante actual,
para que la próxima vez que se mida el tiempo, se mida desde este momento y no desde el anterior.*/

if (digitalRead(segPines[0]) == LOW) {
/*Lee el estado actual del primer pin del display (el segmento "a"). Como ese pin está configurado como OUTPUT,
digitalRead te devuelve lo último que se le escribió con digitalWrite. Si está en LOW, significa que en este
momento el display está apagado (porque cuando se muestra la C ese segmento se prende).*/

for (int i = 0; i < 7; i++) digitalWrite(segPines[i], d7s[4][i]);
/*Si estaba apagado, ahora toca prenderlo: recorre los 7 pines y escribe la fila 4 de la tabla (d7s[4]), que
es el patrón de la "C".*/

 } else {
        for (int i = 0; i < 7; i++) digitalWrite(segPines[i], LOW);
      }
/*Si en cambio el segmento ya estaba en HIGH (la C estaba prendida), hace lo contrario: apaga los 7 segmentos
escribiendo LOW en todos.*/

    }
  }
  break;
/*Cierra el if del parpadeo y cierra el else de los 10 segundos*/